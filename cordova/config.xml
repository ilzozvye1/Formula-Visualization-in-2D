<?xml version='1.0' encoding='utf-8'?>
<widget id="com.formulavisualization.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>2D公式可视化</name>
    <description>
        一个功能强大的2D公式可视化工具，支持多种类型的方程绘制。
    </description>
    <author email="support@formulavisualization.com" href="https://formulavisualization.com">
        Formula Visualization Team
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    
    <!-- 平台配置 -->
    <platform name="android">
        <allow-intent href="market:*" />
        
        <!-- 应用图标 -->
        <icon src="www/assets/icon.png" density="ldpi" />
        <icon src="www/assets/icon.png" density="mdpi" />
        <icon src="www/assets/icon.png" density="hdpi" />
        <icon src="www/assets/icon.png" density="xhdpi" />
        <icon src="www/assets/icon.png" density="xxhdpi" />
        <icon src="www/assets/icon.png" density="xxxhdpi" />
        
        <!-- 偏好设置 -->
        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-targetSdkVersion" value="33" />
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="www/assets/icon.png" />
        <preference name="AndroidWindowSplashScreenBackground" value="#ffffff" />
    </platform>
    
    <!-- 通用偏好设置 -->
    <preference name="Orientation" value="default" />
    <preference name="Fullscreen" value="false" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="BackgroundColor" value="0xffffffff" />
    <preference name="SplashScreenDelay" value="2000" />
    <preference name="FadeSplashScreenDuration" value="500" />
    <preference name="ShowSplashScreenSpinner" value="false" />
    <preference name="SplashMaintainAspectRatio" value="true" />
    <preference name="SplashShowOnlyFirstTime" value="false" />
    
    <!-- WebView设置 -->
    <preference name="AndroidInsecureFileModeEnabled" value="true" />
    <preference name="Scheme" value="app" />
    <preference name="Hostname" value="localhost" />
</widget>
