{
  "name": "formula-visualization-2d",
  "version": "1.0.0",
  "description": "2D公式可视化工具 - 支持多种方程类型的可视化",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder --win --x64"
  },
  "keywords": [
    "math",
    "visualization",
    "formula",
    "equation",
    "2D",
    "graph"
  ],
  "author": "Formula Visualization Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.formulavisualization.2d",
    "productName": "2D公式可视化",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "script.js",
      "styles.css",
      "preload.js",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Formula Visualization Team"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "2D公式可视化"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "assets/icon.png",
      "category": "Education"
    }
  },
  "dependencies": {
    "yauzl": "^3.2.0"
  }
}
